{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "types": ["vitest/globals", "@testing-library/jest-dom", "vite/client"]
  },
  "include": [
    "env.ts",
    "src/vite-env.d.ts",
    "src/env.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/**/__test__/**/*.ts",
    "src/**/__test__/**/*.tsx",
    "vitest.setup.ts"
  ],
  "exclude": []
}
